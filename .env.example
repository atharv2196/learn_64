# ----------------------------------------------------------
# Learn_64 - Environment Configuration
# Copy this file to .env and adjust values.
# ----------------------------------------------------------

# App
APP_NAME="Learn_64"
DEBUG=false

# Database (SQLite default – switch to PostgreSQL for prod)
DATABASE_URL=sqlite+aiosqlite:///./chess_trainer.db
# DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/chess_trainer

# JWT
JWT_SECRET_KEY=change-me-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Stockfish
STOCKFISH_PATH=stockfish
STOCKFISH_DEPTH=18
STOCKFISH_POOL_SIZE=2

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60

# Admin (first account email to become admin)
ADMIN_EMAIL=

# SMTP for OTP emails (required in production)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="Learn_64 <noreply@learn64.com>"
